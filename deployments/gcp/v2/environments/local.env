# =============================================================================
# GCP v2 - Local Environment (Docker Desktop)
# =============================================================================
# No GCP VM - runs locally via Docker

# Target Endpoints - Point to local services or remote backend
WS_URL=ws://host.docker.internal:3000/ws
HEALTH_URL=http://host.docker.internal:3000/health
KAFKA_BROKERS=host.docker.internal:9092

# Loadtest Configuration (reduced for local testing)
TARGET_CONNECTIONS=100
RAMP_RATE=10
DURATION=300
SUBSCRIPTION_MODE=random
CHANNELS=BTC.trade,ETH.trade,SOL.trade
CHANNELS_PER_CLIENT=3

# Publisher Configuration
PUBLISH_RATE=10
