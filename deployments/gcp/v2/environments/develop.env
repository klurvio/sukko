# =============================================================================
# GCP v2 - Develop Environment
# =============================================================================

# GCP Settings
GCP_PROJECT=trim-array-480700-j7
GCP_ZONE=us-central1-a
INSTANCE_NAME=odin-tools-dev
# Machine type: e2-medium (1 vCPU, 4GB) - minimal for POC
MACHINE_TYPE=e2-medium

# Target Endpoints - K8s develop cluster
# Get these IPs after Helm deployment:
#   kubectl get svc -n odin-std-develop odin-ws-gateway odin-redpanda-external
WS_URL=ws://34.133.208.207:443/ws
HEALTH_URL=http://34.133.208.207:443/health
KAFKA_BROKERS=34.67.100.1:9092

# Loadtest Configuration (low-volume for develop testing)
TARGET_CONNECTIONS=100
RAMP_RATE=5
DURATION=300
SUBSCRIPTION_MODE=random
CHANNELS=BTC.trade,ETH.trade,SOL.trade
CHANNELS_PER_CLIENT=2

# Publisher Configuration
PUBLISH_RATE=1
ENVIRONMENT=develop
# KAFKA_TOPIC_NAMESPACE overrides ENVIRONMENT for topic naming
# Defaults to normalized ENVIRONMENT ("dev") if not set
# Set to "main" to publish to production topics for testing:
# KAFKA_TOPIC_NAMESPACE=main
USE_REFINED=true
