# =============================================================================
# GCP v2 - Production Environment
# =============================================================================
# WARNING: Use with caution - this connects to production systems

# GCP Settings
GCP_PROJECT=trim-array-480700-j7
GCP_ZONE=us-central1-a
INSTANCE_NAME=odin-tools-production
MACHINE_TYPE=e2-standard-8    # 8 vCPU, 32GB - supports high connection counts

# Target Endpoints - K8s production cluster
# Get these IPs after deployment:
#   task k8s:standard:external-ips GKE_STD_ENV=production
WS_URL=ws://YOUR_WS_GATEWAY_IP:443/ws
HEALTH_URL=http://YOUR_WS_GATEWAY_IP:443/health
KAFKA_BROKERS=YOUR_REDPANDA_IP:9092

# Loadtest Configuration (conservative for production)
TARGET_CONNECTIONS=50
RAMP_RATE=5
DURATION=60
SUBSCRIPTION_MODE=random
CHANNELS=BTC.trade,ETH.trade,SOL.trade
CHANNELS_PER_CLIENT=2

# Publisher Configuration (low rate for production testing)
PUBLISH_RATE=1
ENVIRONMENT=production
# KAFKA_TOPIC_NAMESPACE defaults to "main" (normalized from "production")
