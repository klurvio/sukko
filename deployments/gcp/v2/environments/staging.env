# =============================================================================
# GCP v2 - Staging Environment
# =============================================================================

# GCP Settings
GCP_PROJECT=trim-array-480700-j7
GCP_ZONE=us-central1-a
INSTANCE_NAME=odin-tools-staging
MACHINE_TYPE=e2-standard-8    # 8 vCPU, 32GB - supports 18K connections

# Target Endpoints - Point to K8s staging or v1 GCP backend
# Update these with your actual endpoint IPs
WS_URL=ws://YOUR_WS_GATEWAY_IP/ws
HEALTH_URL=http://YOUR_WS_GATEWAY_IP/health
KAFKA_BROKERS=YOUR_REDPANDA_IP:9092

# Loadtest Configuration
TARGET_CONNECTIONS=18000
RAMP_RATE=100
DURATION=1800
SUBSCRIPTION_MODE=random
CHANNELS=BTC.trade,ETH.trade,SOL.trade,DOGE.trade,AVAX.trade
CHANNELS_PER_CLIENT=3

# Publisher Configuration
PUBLISH_RATE=25
ENVIRONMENT=staging
# KAFKA_TOPIC_NAMESPACE defaults to "staging" (normalized from "staging")
# Set to "main" to publish to production topics for testing:
# KAFKA_TOPIC_NAMESPACE=main
