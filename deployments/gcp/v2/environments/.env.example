# =============================================================================
# GCP v2 Environment Configuration Template
# =============================================================================
# Copy this file to develop.env or staging.env and configure

# GCP Settings
GCP_PROJECT=your-project-id
GCP_ZONE=us-central1-a
INSTANCE_NAME=odin-tools-dev
MACHINE_TYPE=e2-standard-8

# Target Endpoints (set these for your backend)
WS_URL=ws://YOUR_WS_GATEWAY_IP/ws
HEALTH_URL=http://YOUR_WS_GATEWAY_IP/health
KAFKA_BROKERS=YOUR_REDPANDA_IP:9092

# Loadtest Configuration
TARGET_CONNECTIONS=18000
RAMP_RATE=100
DURATION=1800
SUBSCRIPTION_MODE=random
CHANNELS=BTC.trade,ETH.trade,SOL.trade,DOGE.trade,AVAX.trade
CHANNELS_PER_CLIENT=3

# Publisher Configuration
PUBLISH_RATE=25
