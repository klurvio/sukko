# =============================================================================
# DigitalOcean Tester Deployment Configuration
# =============================================================================
# Copy to config.env and fill in values:
#   cp config.env.example config.env
#
# Get GATEWAY_URL:
#   task k8s:external-ips ENV=demo
# =============================================================================

# Environment name (used in Droplet naming: sukko-tester-<ENVIRONMENT>)
ENVIRONMENT=demo

# DigitalOcean region (should match DOKS cluster region for low latency)
REGION=sfo3

# Droplet size
DROPLET_SIZE=s-2vcpu-4gb

# DO Docker marketplace image (verify current slug: doctl compute image list --public | grep docker)
IMAGE=docker-20-04

# Target Sukko platform (REQUIRED)
GATEWAY_URL=ws://<gateway-ip>:80/ws
PROVISIONING_URL=http://<provisioning-ip>:8080
TESTER_AUTH_TOKEN=<token>
TESTER_PORT=8090
MESSAGE_BACKEND=direct

# Kafka brokers (only needed when MESSAGE_BACKEND=kafka)
# KAFKA_BROKERS=

# GHCR authentication (token with read:packages scope)
# Note: Token is embedded in Droplet user-data (readable on the VM). Use a
# minimal-scope token (read:packages only). Acceptable for ephemeral test VMs.
GHCR_TOKEN=<github-pat>
GHCR_IMAGE=ghcr.io/klurvio/sukko-tester:latest
