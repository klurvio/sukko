# =============================================================================
# GCE Tester Deployment Configuration
# =============================================================================
# Copy to config.env and fill in values:
#   cp config.env.example config.env
#
# Get GATEWAY_URL:
#   task k8s:external-ips PLATFORM=gke ENV=demo
# =============================================================================

# Environment name (used in instance naming: sukko-tester-<ENVIRONMENT>)
ENVIRONMENT=demo

# GCP project and zone (must match GKE cluster)
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-a

# Instance size
INSTANCE_SIZE=e2-medium

# Foundation VPC (instance joins this VPC for internal access to GKE services)
VPC_NETWORK=sukko-demo
VPC_SUBNET=sukko-demo-sukko-subnet

# Target Sukko platform (REQUIRED)
GATEWAY_URL=ws://<gateway-ip>:80/ws
PROVISIONING_URL=http://<provisioning-cluster-ip>:8080
TESTER_AUTH_TOKEN=<token>
TESTER_PORT=8090
MESSAGE_BACKEND=direct

# Kafka brokers (only needed when MESSAGE_BACKEND=kafka)
# KAFKA_BROKERS=

# GHCR authentication (token with read:packages scope)
# Note: Token is embedded in instance metadata (readable on the VM). Use a
# minimal-scope token (read:packages only). Acceptable for ephemeral test VMs.
GHCR_TOKEN=<github-pat>
GHCR_IMAGE=ghcr.io/klurvio/sukko-tester:latest
