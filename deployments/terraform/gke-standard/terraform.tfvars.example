# =============================================================================
# GKE Standard - Example Configuration
# =============================================================================
# Copy this file to terraform.tfvars and update values
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   vim terraform.tfvars  # Set your project_id
#   terraform init
#   terraform plan
#   terraform apply

# =============================================================================
# Project Configuration (REQUIRED)
# =============================================================================

project_id = "your-gcp-project-id"

# =============================================================================
# Region & Zone
# =============================================================================

region = "us-central1"
zone   = "us-central1-a"

# =============================================================================
# Cluster Configuration
# =============================================================================

cluster_name = "odin-ws-gke-standard"
environment  = "develop"  # develop, staging, production
namespace    = "odin-gke-standard"

# =============================================================================
# Network Configuration
# =============================================================================

network_name  = "odin-ws-vpc"
subnet_cidr   = "10.0.0.0/20"
pods_cidr     = "10.1.0.0/16"
services_cidr = "10.2.0.0/20"

# =============================================================================
# Node Pool Configuration
# =============================================================================

node_machine_type = "e2-standard-4"  # 4 vCPU, 16GB RAM (~$97/mo on-demand)
node_disk_size_gb = 50

# Spot VMs - 60-90% cheaper (RECOMMENDED)
use_spot_vms     = true
taint_spot_nodes = false  # Set true if you need dedicated Spot handling

# =============================================================================
# Scaling Configuration
# =============================================================================
# For dev/staging: Fixed 2 nodes (enable_autoscaling = false)
# For production: Autoscaling 1-5 nodes (enable_autoscaling = true)

node_count         = 2      # Fixed count when autoscaling disabled
enable_autoscaling = false  # Set true for production
min_node_count     = 1      # Used when autoscaling enabled
max_node_count     = 5      # Used when autoscaling enabled

# =============================================================================
# Features
# =============================================================================

enable_network_policy           = true
enable_vertical_pod_autoscaling = true
release_channel                 = "REGULAR"  # RAPID, REGULAR, STABLE
deletion_protection             = false      # Set true for production
