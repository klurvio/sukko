# WebSocket Server Configuration
# Copy this file to .env and update values as needed

# Server Configuration
WS_ADDR=:3002
KAFKA_BROKERS=localhost:19092
KAFKA_CONSUMER_GROUP=ws-server-group

# Resource Limits
WS_CPU_LIMIT=1.0
WS_MEMORY_LIMIT=536870912  # 512MB
WS_MAX_CONNECTIONS=500

# Rate Limiting
WS_MAX_KAFKA_RATE=1000
WS_MAX_BROADCAST_RATE=20
WS_MAX_GOROUTINES=1000

# Connection Rate Limiting (DoS Protection)
CONN_RATE_LIMIT_ENABLED=true
CONN_RATE_LIMIT_IP_BURST=10
CONN_RATE_LIMIT_IP_RATE=1.0
CONN_RATE_LIMIT_GLOBAL_BURST=300
CONN_RATE_LIMIT_GLOBAL_RATE=50.0

# CPU Safety Thresholds
WS_CPU_REJECT_THRESHOLD=75.0
WS_CPU_PAUSE_THRESHOLD=80.0

# TCP/Network Tuning
TCP_LISTEN_BACKLOG=2048
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# Monitoring
METRICS_INTERVAL=15s

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Environment
ENVIRONMENT=development

# ================================
# Valkey Configuration (BroadcastBus)
# ================================
# For local development (single Valkey instance):
VALKEY_ADDRS=localhost:6379
VALKEY_MASTER_NAME=mymaster
VALKEY_PASSWORD=testpassword
VALKEY_DB=0
VALKEY_CHANNEL=ws.broadcast

# For production (Valkey Sentinel cluster):
# VALKEY_ADDRS=valkey-1:26379,valkey-2:26379,valkey-3:26379
# VALKEY_MASTER_NAME=mymaster
# VALKEY_PASSWORD=<production-password>
# VALKEY_DB=0
# VALKEY_CHANNEL=ws.broadcast

# For GCP Memorystore for Valkey (managed):
# VALKEY_ADDRS=10.0.0.3:6379
# VALKEY_MASTER_NAME=mymaster
# VALKEY_PASSWORD=<gcp-generated-password>
# VALKEY_DB=0
# VALKEY_CHANNEL=ws.broadcast
