# WebSocket Server Configuration
# Copy this file to .env and update values as needed

# Server Configuration
WS_ADDR=:3002
KAFKA_BROKERS=localhost:19092
KAFKA_CONSUMER_GROUP=ws-server-group

# Resource Limits
WS_CPU_LIMIT=1.0
WS_MEMORY_LIMIT=536870912  # 512MB
WS_MAX_CONNECTIONS=500

# Rate Limiting
WS_MAX_KAFKA_RATE=1000
WS_MAX_BROADCAST_RATE=20
WS_MAX_GOROUTINES=1000

# Connection Rate Limiting (DoS Protection)
CONN_RATE_LIMIT_ENABLED=true
CONN_RATE_LIMIT_IP_BURST=10
CONN_RATE_LIMIT_IP_RATE=1.0
CONN_RATE_LIMIT_GLOBAL_BURST=300
CONN_RATE_LIMIT_GLOBAL_RATE=50.0

# CPU Safety Thresholds
WS_CPU_REJECT_THRESHOLD=75.0
WS_CPU_PAUSE_THRESHOLD=80.0

# TCP/Network Tuning
TCP_LISTEN_BACKLOG=2048
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# Monitoring
METRICS_INTERVAL=15s

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Environment
ENVIRONMENT=development

# ================================
# Redis Configuration (BroadcastBus)
# ================================
# For local development (single Redis instance):
REDIS_SENTINEL_ADDRS=localhost:6379
REDIS_MASTER_NAME=mymaster
REDIS_PASSWORD=testpassword
REDIS_DB=0
REDIS_CHANNEL=ws.broadcast

# For production (Redis Sentinel cluster):
# REDIS_SENTINEL_ADDRS=redis-1:26379,redis-2:26379,redis-3:26379
# REDIS_MASTER_NAME=mymaster
# REDIS_PASSWORD=<production-password>
# REDIS_DB=0
# REDIS_CHANNEL=ws.broadcast

# For GCP Memorystore (managed Redis):
# REDIS_SENTINEL_ADDRS=10.0.0.3:6379
# REDIS_MASTER_NAME=mymaster
# REDIS_PASSWORD=<gcp-generated-password>
# REDIS_DB=0
# REDIS_CHANNEL=ws.broadcast
