# Valkey Configuration for WebSocket BroadcastBus
# Copy this file to .env and update with production values

# ==================== VALKEY CONNECTION ====================
# Password: Generate with: openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
# IMPORTANT: Use a strong, random password for production
VALKEY_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# ==================== VALKEY CONFIGURATION ====================
# Maximum memory (should be ~50% of VM RAM for safety)
# e2-standard-2 has 8GB RAM, so 4GB for Valkey is safe
VALKEY_MAX_MEMORY=4gb

# Log level: debug, verbose, notice, warning
VALKEY_LOG_LEVEL=notice

# ==================== MONITORING ====================
# Valkey Exporter configuration
VALKEY_EXPORTER_LOG_LEVEL=info

# ==================== NETWORK ====================
# Bind address (0.0.0.0 for all interfaces, secured by firewall)
VALKEY_BIND_ADDRESS=0.0.0.0
VALKEY_PORT=6379

# ==================== BACKUP ====================
# Backup directory (for debugging/disaster recovery)
# Note: Pub/Sub data is ephemeral, backups are optional
BACKUP_DIR=./backups

# ==================== NOTES ====================
# Single Node Configuration:
#   - Start with this for development and initial production
#   - Cost: ~$53/month (e2-standard-2)
#   - No automatic failover
#
# To upgrade to Sentinel later:
#   1. Deploy 3 Valkey nodes
#   2. Configure Sentinel (see docker-compose.sentinel.yml)
#   3. Update ws-server VALKEY_SENTINEL_ADDRS to 3 addresses
#   4. Zero code changes needed!
#
# WS Server Connection:
#   Single node: VALKEY_ADDRS=10.128.0.10:6379
#   Sentinel:    VALKEY_ADDRS=10.128.0.10:26379,10.128.0.11:26379,10.128.0.12:26379
