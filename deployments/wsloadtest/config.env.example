# =============================================================================
# wsloadtest Configuration
# =============================================================================
# Copy to config.env and fill in values:
#   cp config.env.example config.env
#
# Get WS_URL:
#   kubectl get svc odin-ws-gateway -n <namespace> -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# =============================================================================

# GCP Project
PROJECT=trim-array-480700-j7

# Zone for VM
ZONE=us-central1-a

# Network (must match target cluster's VPC)
NETWORK=odin-ws-staging-vpc
SUBNET=odin-ws-staging-vpc-subnet

# WebSocket target URL (REQUIRED - get from kubectl command above)
# Example: ws://34.x.x.x:3000/ws
WS_URL=

# VM Settings
MACHINE_TYPE=e2-standard-8
VM_NAME=wsloadtest-vm

# Container image
REGISTRY=us-central1-docker.pkg.dev/${PROJECT}/odin
IMAGE_TAG=latest

# Load Test Parameters
TARGET_CONNECTIONS=5000
RAMP_RATE=100
DURATION=10m
