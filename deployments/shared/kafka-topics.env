# =============================================================================
# Kafka Topics Configuration
# =============================================================================
# Purpose: Single source of truth for Kafka topic configuration
# Used by: Publisher, WS Server, topic creation scripts
#
# Topic Naming Pattern:
#   Regular:  odin.{env}.{base}          (e.g., odin.dev.trade)
#   Refined:  odin.{env}.{base}.refined  (e.g., odin.dev.trade.refined)
#
# Data Flow:
#   Publisher → regular topics → External Service → refined topics → ws-server

# =============================================================================
# TOPIC BASE NAMES
# =============================================================================
# Base names without environment prefix (used to construct full topic names)
KAFKA_TOPIC_BASES=trade,liquidity,balances,metadata,social,community,creation,analytics

# =============================================================================
# TOPIC NAMESPACE (for topic naming)
# =============================================================================
# Valid namespaces: local, dev, staging, main
#   - local:   Local development
#   - dev:     Development/testing environment
#   - staging: Pre-production environment
#   - main:    Production environment (renamed from "prod" for clarity)
#
# Note: "prod" and "production" are normalized to "main"
#       "develop" and "development" are normalized to "dev" or "local"
#
# Default: local (for local development)
KAFKA_ENVIRONMENT=local

# =============================================================================
# TOPIC CONFIGURATION
# =============================================================================
# Partitions per topic (parallel processing)
KAFKA_PARTITIONS=12

# Replication factor (1 = no replication for local/single-broker)
KAFKA_REPLICAS=1

# =============================================================================
# RETENTION POLICIES (Per-Topic Base)
# =============================================================================
# Format: base_topic:retention_time
# Applied to both regular and refined versions of each topic
KAFKA_RETENTION_trade=30s
KAFKA_RETENTION_liquidity=60s
KAFKA_RETENTION_metadata=1h
KAFKA_RETENTION_social=1h
KAFKA_RETENTION_community=5m
KAFKA_RETENTION_creation=1h
KAFKA_RETENTION_analytics=5m
KAFKA_RETENTION_balances=30s
