#!/usr/bin/env bash
# Pre-commit hook: Go linting, formatting, and Helm chart validation
# Install: git config core.hooksPath .githooks

set -e

YELLOW='\033[0;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Track failures
FAILED=0

# ---------------------------------------------------------------------------
# 1. Go formatting and vetting (only if Go files changed)
# ---------------------------------------------------------------------------
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$GO_FILES" ]; then
  echo -e "\n${YELLOW}[Go] Checking formatting...${NC}"

  # Check gofmt
  UNFORMATTED=$(gofmt -l $GO_FILES 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}[Go] These files need formatting:${NC}"
    echo "$UNFORMATTED"
    echo -e "${YELLOW}[Go] Auto-formatting...${NC}"
    gofmt -w $GO_FILES
    gofmt -s -w $GO_FILES
    echo -e "${YELLOW}[Go] Files formatted. Please re-stage and commit again.${NC}"
    FAILED=1
  fi

  echo -e "${YELLOW}[Go] Running go vet...${NC}"
  if ! (cd ws && go vet ./... 2>&1); then
    echo -e "${RED}[Go] go vet failed${NC}"
    FAILED=1
  else
    echo -e "${GREEN}[Go] go vet passed${NC}"
  fi

  # golangci-lint (if installed)
  if command -v golangci-lint &> /dev/null; then
    echo -e "${YELLOW}[Go] Running golangci-lint...${NC}"
    if ! (cd ws && golangci-lint run --fix ./... 2>&1); then
      echo -e "${RED}[Go] golangci-lint found issues${NC}"
      FAILED=1
    else
      echo -e "${GREEN}[Go] golangci-lint passed${NC}"
    fi
  fi
fi

# ---------------------------------------------------------------------------
# 2. Go mod tidy check (only if go.mod or go.sum changed)
# ---------------------------------------------------------------------------
MOD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(go\.mod|go\.sum)$' || true)

if [ -n "$MOD_FILES" ]; then
  echo -e "\n${YELLOW}[Go] Checking go mod tidy...${NC}"
  (cd ws && go mod tidy 2>/dev/null)
  if ! git diff --quiet ws/go.mod ws/go.sum 2>/dev/null; then
    echo -e "${RED}[Go] go.mod/go.sum not tidy. Run 'cd ws && go mod tidy' and re-stage.${NC}"
    FAILED=1
  else
    echo -e "${GREEN}[Go] go mod tidy is clean${NC}"
  fi
fi

# ---------------------------------------------------------------------------
# 3. Helm chart linting (only if Helm files changed)
# ---------------------------------------------------------------------------
HELM_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'deployments/helm/' || true)

if [ -n "$HELM_FILES" ] && command -v helm &> /dev/null; then
  echo -e "\n${YELLOW}[Helm] Linting charts...${NC}"

  # Find unique chart directories from changed files
  CHART_DIRS=$(echo "$HELM_FILES" | while read -r f; do
    dir="$f"
    while [ "$dir" != "." ] && [ ! -f "$dir/Chart.yaml" ]; do
      dir=$(dirname "$dir")
    done
    if [ -f "$dir/Chart.yaml" ]; then
      echo "$dir"
    fi
  done | sort -u)

  for chart_dir in $CHART_DIRS; do
    echo -e "${YELLOW}[Helm] Linting $chart_dir...${NC}"
    if helm lint "$chart_dir" 2>&1; then
      echo -e "${GREEN}[Helm] $chart_dir passed${NC}"
    else
      echo -e "${RED}[Helm] $chart_dir has issues (non-blocking)${NC}"
      # Helm lint errors are non-blocking — charts may need parent values to lint cleanly
    fi
  done
fi

# ---------------------------------------------------------------------------
# 4. Buf lint for protobuf files (only if proto files changed)
# ---------------------------------------------------------------------------
PROTO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.proto$' || true)

if [ -n "$PROTO_FILES" ] && command -v buf &> /dev/null; then
  echo -e "\n${YELLOW}[Proto] Running buf lint...${NC}"
  if (cd ws && buf lint 2>&1); then
    echo -e "${GREEN}[Proto] buf lint passed${NC}"
  else
    echo -e "${RED}[Proto] buf lint failed${NC}"
    FAILED=1
  fi
fi

# ---------------------------------------------------------------------------
# 5. YAML lint for Taskfiles (only if Taskfiles changed)
# ---------------------------------------------------------------------------
TASK_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(Taskfile\.yml|taskfiles/)' || true)

if [ -n "$TASK_FILES" ] && command -v yamllint &> /dev/null; then
  echo -e "\n${YELLOW}[YAML] Linting Taskfiles...${NC}"
  YAMLLINT_CONFIG=""
  if [ -f ".yamllint.yaml" ]; then
    YAMLLINT_CONFIG="-c .yamllint.yaml"
  else
    YAMLLINT_CONFIG="-d relaxed"
  fi

  if yamllint $YAMLLINT_CONFIG $TASK_FILES 2>&1; then
    echo -e "${GREEN}[YAML] Taskfiles passed${NC}"
  else
    echo -e "${RED}[YAML] Taskfile lint issues (non-blocking)${NC}"
    # Non-blocking — yamllint can be overly strict
  fi
fi

# ---------------------------------------------------------------------------
# 6. Binary file check
# ---------------------------------------------------------------------------
BINARY_STAGED=$(git diff --cached --name-only --diff-filter=ACM | while read -r f; do
  if file --mime "$f" 2>/dev/null | grep -q "charset=binary"; then
    echo "$f"
  fi
done)

if [ -n "$BINARY_STAGED" ]; then
  echo -e "\n${RED}[Binary] These binary files are staged:${NC}"
  echo "$BINARY_STAGED"
  echo -e "${YELLOW}Unstage with: git reset HEAD <file>${NC}"
  FAILED=1
fi

# ---------------------------------------------------------------------------
# 7. Secrets check
# ---------------------------------------------------------------------------
SECRETS_FOUND=$(git diff --cached --diff-filter=ACM -p | grep -iE '(password|secret|api_key|private_key|token)(\s*[:=]\s*["\x27][^\x27"]+)' | grep -v '_test\.go' | grep -v '\.md' | grep -v 'envDefault' | head -5 || true)

if [ -n "$SECRETS_FOUND" ]; then
  echo -e "\n${RED}[Security] Potential secrets detected in staged changes:${NC}"
  echo "$SECRETS_FOUND"
  echo -e "${YELLOW}Review these lines carefully before committing.${NC}"
  # Non-blocking — false positives are common in Go struct tags
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
if [ $FAILED -ne 0 ]; then
  echo -e "${RED}Pre-commit checks failed. Fix issues and try again.${NC}"
  exit 1
else
  echo -e "${GREEN}All pre-commit checks passed.${NC}"
fi
